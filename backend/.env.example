NODE_ENV=development
PORT=3001

# Supabase PostgreSQL (use port 6543 for pgBouncer pooling in production)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Upstash Redis
UPSTASH_REDIS_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# For BullMQ (ioredis format)
REDIS_HOST=your_upstash_hostname
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_password
REDIS_TLS=true

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Public URL of this backend (used to build short URLs)
BASE_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
